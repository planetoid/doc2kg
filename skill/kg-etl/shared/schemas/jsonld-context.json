{
  "@context": {
    "rdf":    "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs":   "http://www.w3.org/2000/01/rdf-schema#",
    "owl":    "http://www.w3.org/2002/07/owl#",
    "xsd":    "http://www.w3.org/2001/XMLSchema#",
    "schema": "https://schema.org/",
    "foaf":   "http://xmlns.com/foaf/0.1/",
    "org":    "http://www.w3.org/ns/org#",
    "prov":   "http://www.w3.org/ns/prov#",
    "ex":     "https://example.org/entity/",

    "label":       { "@id": "rdfs:label",       "@container": "@language" },
    "type":        { "@id": "rdf:type",          "@type": "@id" },
    "location":    { "@id": "schema:location",   "@type": "@id" },
    "memberOf":    { "@id": "org:memberOf",       "@type": "@id" },
    "founder":     { "@id": "schema:founder",     "@type": "@id" },
    "isPartOf":    { "@id": "schema:isPartOf",    "@type": "@id" },
    "datePublished":{ "@id": "schema:datePublished","@type": "xsd:date" },
    "citation":    { "@id": "schema:citation",    "@type": "@id" },
    "colleague":   { "@id": "schema:colleague",   "@type": "@id" },
    "confidence":  { "@id": "ex:confidence",      "@type": "xsd:decimal" },
    "sourceSpan":  { "@id": "ex:sourceSpan" }
  }
}
